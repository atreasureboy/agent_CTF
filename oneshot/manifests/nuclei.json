{
  "id": "nuclei",
  "displayName": "nuclei (limited templates)",
  "category": "web",
  "description": "Run a restricted nuclei template set against a single approved target.",
  "source": {
    "repository": "https://github.com/projectdiscovery/nuclei",
    "license": "MIT",
    "pinnedRef": "v3.1.0",
    "imageDigest": "sha256:9fe12a8ba0e964580f98163686fb9174659d160570ba9c05357d5008de2829d4"
  },
  "maturity": "stable",
  "enabledByDefault": false,
  "inputMatchers": {
    "taskTags": [
      "network"
    ]
  },
  "allowedProfiles": [
    "web"
  ],
  "runner": {
    "type": "container",
    "image": "projectdiscovery/nuclei:v3.1.0",
    "command": [
      "nuclei",
      "-severity",
      "medium,high,critical",
      "-t",
      "cves/",
      "-t",
      "vulnerabilities/"
    ]
  },
  "resources": {
    "timeoutSeconds": 900,
    "memoryMb": 1024,
    "maxOutputBytes": 262144
  },
  "network": {
    "mode": "contest-target-only",
    "requiresScopeApproval": true
  },
  "output": {
    "parser": "jsonl"
  },
  "scheduling": {
    "costTier": "medium",
    "estimatedSeconds": 600,
    "falsePositiveRisk": "medium"
  },
  "healthcheck": {
    "command": [
      "docker",
      "run",
      "--rm",
      "projectdiscovery/nuclei:v3.1.0",
      "nuclei",
      "-version"
    ]
  }
}
